{
  "name": "mustache-historian",
  "version": "1.0.0",
  "description": "Data and utilities for the Mustache Historian fundraising tracker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./server.d.ts",
      "default": "./server.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "data",
    "server.js",
    "server.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "csv-parse": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "keywords": ["mustache", "fundraising", "omaha"],
  "license": "MIT"
}
